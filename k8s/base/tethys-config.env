# Script/Job environment knobs - NOT Django settings.
# (Django/portal settings live in portal_config.yml, generated into the
#  tethys-portal-config ConfigMap. Edit these here for shell/Job behavior only.)
# Paths the scripts/container use
TETHYS_HOME=/usr/lib/tethys
TETHYS_LOG=/var/log/tethys
TETHYS_PERSIST=/var/lib/tethys_persist
TETHYS_APPS_ROOT=/var/www/tethys/apps
TETHYS_WORKSPACES_ROOT=/var/lib/tethys_persist/workspaces
TETHYS_MANAGE=/usr/lib/tethys/tethys/tethys_portal/manage.py
TETHYS_PORT=8000
# DB host the web pods use (portal-config.sh stamps it into portal_config.yml,
# overriding the image default of "db"). Normally the pooler; set to the direct
# primary (tethys-postgres-rw) ONLY for the Demo 2 "too many clients" exercise.
TETHYS_DB_HOST=tethys-postgres-rw
# uvicorn workers per pod. KEEP THIS AT 1. Tethys runs synchronous DB queries at
# import time (tethys_apps/admin.py), and uvicorn --workers >1 imports the app inside
# an asyncio event loop -> Django raises SynchronousOnlyOperation and the workers die.
# Scale the web tier with REPLICAS / HPA, not in-process uvicorn workers.
ASGI_PROCESSES=1

# nginx: substituted into default.conf.template by the nginx image's envsubst.
# (Align with Django's upload limit in portal_config.yml if you change it.)
CLIENT_MAX_BODY_SIZE=100m