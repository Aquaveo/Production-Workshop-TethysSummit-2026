# Docker-Compose environment. Django/portal SETTINGS and site branding are NOT here --
# they are declarative in conf/portal_config.yml (mounted into tethys-init). This file
# only holds infrastructure knobs: paths, DB credentials, the portal admin, and secrets.

# Paths -- all under /home/tethys so the non-root image user (uid 1000) owns them.
# Must match the paths baked into the Dockerfile.
TETHYS_HOME="/home/tethys/portal"
TETHYS_LOG="/home/tethys/log"
TETHYS_PERSIST="/home/tethys/persist"
TETHYS_APPS_ROOT="/home/tethys/apps"
TETHYS_WORKSPACES_ROOT="/home/tethys/persist/workspaces"
STATIC_ROOT="${TETHYS_PERSIST}/static"
MEDIA_ROOT="${TETHYS_PERSIST}/media"
WORKSPACE_ROOT="${TETHYS_PERSIST}/workspaces"

# App / server
TETHYS_PORT=8000
ASGI_PROCESSES=1

# Postgres bootstrap -- read by conf/postgres-initdb/10-create-tethys-db.sh (which
# creates the roles + database on first boot) and by portal-config.sh (HOST/PASSWORD).
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="pass"
TETHYS_DB_ENGINE='django.db.backends.postgresql'
TETHYS_DB_NAME='tethys_platform'
TETHYS_DB_USERNAME="tethys_default"
TETHYS_DB_PASSWORD="pass"
TETHYS_DB_HOST="postgres"
TETHYS_DB_PORT=5432
# Web tier connects through the PgBouncer pooler (the pgbouncer service); migrations in
# init-tethys.sh run direct against TETHYS_DB_HOST first, then flip the config to this.
# Leave empty to disable pooling (web would use TETHYS_DB_HOST directly).
TETHYS_POOLER_HOST="pgbouncer"
TETHYS_DB_SUPERUSER="tethys_super"
TETHYS_DB_SUPERUSER_PASS="pass"
# Least-privilege role for app persistent stores (Option B): CREATEDB but NOT superuser,
# so a persistent-store app owns its store DB and never runs as super at runtime.
# Used by scripts/provision-persistent-store.sh.
TETHYS_APP_DB_USERNAME="tethys_app"
TETHYS_APP_DB_PASSWORD="pass"

# Portal admin -- read by portal-bootstrap.sh (tethys db createsuperuser).
PORTAL_SUPERUSER_NAME="admin"
PORTAL_SUPERUSER_EMAIL=""
PORTAL_SUPERUSER_PASSWORD="pass"

# Injected into portal_config.yml by portal-config.sh (k8s sources it from a Secret).
# Generate a real one for anything but a local workshop:
#   python -c "from django.core.management.utils import get_random_secret_key as k; print(k())"
TETHYS_SECRET_KEY="dev-only-not-for-production-change-me"